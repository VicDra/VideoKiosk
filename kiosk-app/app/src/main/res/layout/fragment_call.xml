<?xml version="1.0" encoding="utf-8"?>
<!--
    Call screen layout.
    - remote_renderer: full-screen WebRTC SurfaceViewRenderer for operator video
    - local_renderer:  small PiP in bottom-right corner for local camera preview
    - btn_end_call:    overlaid button to terminate the call
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Remote video — full screen -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_renderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Local video — picture-in-picture, bottom right -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/local_renderer"
        android:layout_width="140dp"
        android:layout_height="100dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:elevation="4dp" />

    <!-- End call button — bottom center, overlaid on video -->
    <Button
        android:id="@+id/btn_end_call"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#F44336"
        android:text="@string/btn_end_call"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:elevation="8dp" />

</FrameLayout>
