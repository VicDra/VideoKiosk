{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"C:\\ClaudeCodes\\VideoKiosk\\.claude\\git-autopush.ps1\"",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Pushing to GitHub..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(git -C * *)"
    ]
  }
}
